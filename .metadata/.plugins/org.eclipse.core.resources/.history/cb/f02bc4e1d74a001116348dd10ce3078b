// To deal with echo pin from sampling stm
void HAL_GPIO_EXTI_Callback(uint16_t GPIO_Pin)
{
    // to handle the rising edge and failling edge of the Echo
    if (GPIO_Pin == GPIO_PIN_6 && operation_mode == DISTANCE_TRIGGERED)  // PB7
    {
        if (HAL_GPIO_ReadPin(GPIOB, GPIO_PIN_6) == GPIO_PIN_SET && state == RUNNING)
        {
            // rising edge, the object is out of range
            HAL_DMA_Abort_IT(&hdma_spi1_rx);
//            HAL_DMA_Abort_IT(&hdma_usart2_tx);
            LL_DMA_DisableChannel(DMA1, LL_DMA_CHANNEL_7);  // stop the DMA transfer
//            while (__HAL_UART_GET_FLAG(&huart2, UART_FLAG_TC) == RESET);   // make sure all DMA transmission is done before continuing
//            huart2.gState = HAL_UART_STATE_READY;  // force HAL state back to ready
            while(!LL_USART_IsActiveFlag_TC(USART2));  // wait for transmission complete
            LL_USART_ClearFlag_TC(USART2);             // clear the flag

            // send out 4 bytes of 0xFF to signal that we are stopping
            uint8_t stop_val = 255;
            for (int i = 0; i < 4; i++){
                UART2_Transmit_Blocking(stop_val);
            };

            state = OUT_OF_DISTANCE;

        }
        else if (HAL_GPIO_ReadPin(GPIOB, GPIO_PIN_6) != GPIO_PIN_SET && state == OUT_OF_DISTANCE)
        {
            // falling edge, means that the object is within range again
            // re-arms the spi dma; refresh all the controlling parameter for SPI DMA
            counter = 0;
            average = 0;
            initialise = 0;
            cumulative_sample = 0;
            downsample = 0;
//        	window_idx = 0;
//        	for (int i = 0; i< WINDOW_SIZE; i++){
//        		window[i] = 0;
//        	}
//
//        	for (int i = 0; i < CHUNK_SIZE * 2; i++){
//        		rxBuffer[i] = 0;
//        	}
//        	running_sum = 0;
            state = RUNNING;
//            huart2.gState = HAL_UART_STATE_READY;
            while(!LL_USART_IsActiveFlag_TC(USART2));  // wait for transmission complete
            LL_USART_ClearFlag_TC(USART2);             // clear the flag
            hspi1.State = HAL_SPI_STATE_READY;
            HAL_SPI_Receive_DMA(&hspi1,(uint8_t*)(downsample_buffer + downsample), 1);
        }
    }
}

// called whenever receive something from SPI
void HAL_SPI_RxCpltCallback(SPI_HandleTypeDef *hspi){

	if (hspi->Instance == SPI1) {
		HAL_GPIO_TogglePin(Test2_GPIO_Port, Test2_Pin);
		downsample ^= 0x1;
		HAL_SPI_Receive_DMA(&hspi1, (uint8_t*)(downsample_buffer + downsample), 1);
		if (downsample == 0){
			HAL_GPIO_WritePin(Test2_GPIO_Port, Test2_Pin,1);

			uint16_t value = (downsample_buffer[0] >> 1) + (downsample_buffer[1] >> 1);

			if (initialise >= 2){

				uint16_t val1 = history[0];
				uint16_t val2 = history[1];

				if ((val1 <= val2) && (val1 <= value)){
					chosen = (value <= val2)? value : val2;
				} else if ((val2 <= val1) && (val2 <= value)){
					chosen = (value <= val1) ? value : val1;
				} else{
					chosen = (val1 <= val2) ? val1 : val2;
				};

				history[1] = history[0];
				history[0] = value;

			} else{
				if (initialise){
					history[1] = value;
				} else{
					history[0] = value;
				}
			}

			prev = rxBuffer[counter];
			rxBuffer[counter] = chosen;

			cumulative_sample += chosen;

			if (initialise == WINDOW_SIZE - 1) // doesn't send first few datapoints until average can be computed
			{
//	//			HAL_GPIO_WritePin(Test_GPIO_Port, Test_Pin,1);
//				cumulative_sample = 0; // calculates average
//				for (uint8_t i = 0; i < WINDOW_SIZE; i++)
//				{
//					cumulative_sample += rxBuffer[i];
//				}

				average = cumulative_sample >> 3;
				static uint8_t data_for_transmission;
				data_for_transmission = (uint8_t)(average >> 2);

//				HAL_UART_Transmit_DMA(&huart2, &data_for_transmission, 1);
				UART2_DMA_Transmit(&data_for_transmission);
//				HAL_GPIO_WritePin(Test_GPIO_Port, Test_Pin,0);
				initialise++;
			}else if (initialise > WINDOW_SIZE - 1){
				cumulative_sample -= prev;
				average = cumulative_sample >> 3;
				static uint8_t data_for_transmission;
				data_for_transmission = (uint8_t)(average >> 2);

//				HAL_GPIO_WritePin(Test2_GPIO_Port, Test2_Pin,0);
//				HAL_UART_Transmit_DMA(&huart2, &data_for_transmission, 1);
				UART2_DMA_Transmit(&data_for_transmission);

			} else {
				initialise ++;
			};

			counter++;
			if (counter == WINDOW_SIZE){ // loops the counter around for each index in the window size
				counter = 0;
	//				HAL_GPIO_TogglePin(Test_GPIO_Port, Test_Pin);
			}
		}
	}
}
