void UART2_DMA_Transmit(uint8_t *data){
    while(LL_DMA_IsEnabledChannel(DMA1, LL_DMA_CHANNEL_7));
    LL_DMA_DisableChannel(DMA1, LL_DMA_CHANNEL_7);
    LL_DMA_SetMemoryAddress(DMA1, LL_DMA_CHANNEL_7, (uint32_t)data);
    LL_DMA_SetDataLength(DMA1, LL_DMA_CHANNEL_7, 1);
    LL_DMA_EnableChannel(DMA1, LL_DMA_CHANNEL_7);
}

void UART2_Transmit_Blocking(uint8_t data){
    while(!LL_USART_IsActiveFlag_TXE(USART2));  // wait for TX register empty
    LL_USART_TransmitData8(USART2, data);
    while(!LL_USART_IsActiveFlag_TC(USART2));   // wait for transmission complete
    LL_USART_ClearFlag_TC(USART2);
}

